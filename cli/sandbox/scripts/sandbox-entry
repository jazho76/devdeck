#!/usr/bin/env bash
set -uo pipefail

if [ ! -d "$HOME/.local/share/devdeck/source" ]; then
  echo "Installing devdeck..."
  devdeck install --all || echo "devdeck install failed"
fi

cat <<'USAGE'

  devdeck sandbox (ready) - disposable Fedora box with core prereqs baked in.
  `devdeck install --all` runs automatically on first start; the locally-built
  `devdeck` binary is mounted at ~/.local/bin.

  Exit the shell to destroy the container.

USAGE

exec bash
