#!/usr/bin/env bash
set -uo pipefail

install -m 0755 /opt/devdeck-bin "$HOME/.local/bin/devdeck"

if [ ! -d "$HOME/.local/share/devdeck/source" ]; then
  # echo "Installing devdeck..."
  # devdeck install --no-toolsets || echo "devdeck install failed"
fi

cat <<'USAGE'

  devdeck sandbox - disposable Fedora box with core prereqs baked in.
  Exit the shell to destroy the container.

USAGE

exec bash
